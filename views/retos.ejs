<!DOCTYPE html>
<html class="dark" lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RondaCero - Retos</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;1,400;1,500&family=Lexend:wght@600&family=Spline+Sans:wght@700;800&display=swap" rel="stylesheet"/>
  <script>
  tailwind.config={darkMode:"class",theme:{extend:{colors:{"surface-bright":"#303b41","surface-dim":"#0a151a","secondary-fixed-dim":"#5bd5fc","background":"#0a151a","inverse-surface":"#d8e4ec","on-surface":"#d8e4ec","inverse-primary":"#745c00","surface":"#0a151a","surface-container-low":"#121d23","on-primary-container":"#725a00","on-tertiary-container":"#b8005e","secondary-container":"#00a3c8","primary-container":"#ffd23f","on-error":"#690005","surface-container-highest":"#2b363d","primary-fixed":"#ffe089","surface-variant":"#2b363d","on-secondary-container":"#003341","tertiary-fixed-dim":"#ffb1c6","on-error-container":"#ffdad6","on-surface-variant":"#d1c5ad","error-container":"#93000a","secondary-fixed":"#b7eaff","outline-variant":"#4d4634","error":"#ffb4ab","surface-container-lowest":"#051015","inverse-on-surface":"#273238","on-tertiary-fixed":"#3f001c","tertiary-container":"#ffc9d6","on-secondary-fixed":"#001f28","on-tertiary":"#650031","on-primary-fixed":"#241a00","primary-fixed-dim":"#edc22e","tertiary":"#fff0f2","surface-tint":"#edc22e","surface-container-high":"#202b32","on-secondary-fixed-variant":"#004e61","secondary":"#5bd5fc","on-primary-fixed-variant":"#574500","on-secondary":"#003543","on-primary":"#3d2f00","primary":"#fff2d7","outline":"#9a907a","on-background":"#d8e4ec","surface-container":"#162127","tertiary-fixed":"#ffd9e1","on-tertiary-fixed-variant":"#8e0048"},fontFamily:{"body-sm":["Be Vietnam Pro"],"body-lg":["Be Vietnam Pro"],"headline-xl":["Spline Sans"],"label-bold":["Lexend"],"bilingual-sub":["Be Vietnam Pro"],"headline-md":["Spline Sans"]},fontSize:{"body-sm":["14px",{"lineHeight":"1.5","fontWeight":"400"}],"body-lg":["18px",{"lineHeight":"1.6","fontWeight":"400"}],"headline-xl":["48px",{"lineHeight":"1.1","letterSpacing":"-0.02em","fontWeight":"800"}],"label-bold":["14px",{"lineHeight":"1.0","fontWeight":"600"}],"bilingual-sub":["12px",{"lineHeight":"1.2","fontWeight":"500"}],"headline-md":["32px",{"lineHeight":"1.2","fontWeight":"700"}]},borderRadius:{"DEFAULT":"0.25rem","lg":"0.5rem","xl":"0.75rem","full":"9999px"},spacing:{"margin":"24px","chunky-gap":"12px","gutter":"16px","container-max":"1200px","unit":"8px"}}}}
  </script>
  <style>
    .rough-border{border:4px solid #000;border-radius:4px 8px 3px 6px}
    .rough-shadow{box-shadow:4px 4px 0px 0px rgba(0,0,0,1)}
    .rough-shadow-lg{box-shadow:8px 8px 0px 0px rgba(0,0,0,1)}
    .rough-button:active{box-shadow:none;transform:translate(4px,4px)}
    .paper-stack{position:relative}
    .paper-stack::before{content:'';position:absolute;top:4px;left:-4px;right:4px;bottom:-4px;border:4px solid #000;background:#2b363d;z-index:-1;transform:rotate(-1deg)}
    .error-msg{background:#93000a;color:#ffdad6;border:2px solid black}
    .game-card{transition:transform 0.3s}
    .game-card:hover{transform:rotate(0deg) scale(1.05)!important}
    ::selection{background:#ffd23f;color:black}
    .bar-fill{transition:width 0.5s ease;background:linear-gradient(90deg,#ffd23f,#ef476f)}
  </style>
</head>
<body class="bg-background text-on-background min-h-screen font-body-lg">

<%- include('partials/header') %>

<main class="flex-1 px-gutter py-margin max-w-container-max mx-auto w-full flex flex-col items-center justify-center">

  <div class="text-center mb-margin">
    <p class="font-body-sm text-on-surface-variant uppercase tracking-wider mb-unit">Jugador seleccionado</p>
    <h1 id="player-name" class="font-headline-md text-headline-md text-primary-container">—</h1>
  </div>

  <div class="paper-stack bg-surface-container-high rough-border rough-shadow-lg p-8 w-full max-w-lg text-center mb-margin" style="transform: rotate(-0.5deg);">
    <span class="material-symbols-outlined text-6xl text-primary-container mb-unit">fitness_center</span>
    <p id="reto-text" class="font-body-lg text-body-lg text-on-surface">
      Esperando reto...
    </p>
  </div>

  <div id="accept-reject-section" class="flex gap-chunky-gap mb-margin hidden">
    <button id="btn-aceptar"
            class="rough-border rough-shadow rough-button bg-green-700 text-white font-label-bold text-lg px-8 py-4 uppercase tracking-wide">
      <span class="material-symbols-outlined align-middle mr-1">check_circle</span>
      ACEPTAR
    </button>
    <button id="btn-rechazar"
            class="rough-border rough-shadow rough-button bg-error-container text-on-error-container font-label-bold text-lg px-8 py-4 uppercase tracking-wide">
      <span class="material-symbols-outlined align-middle mr-1">cancel</span>
      RECHAZAR
    </button>
  </div>

  <div id="voting-section" class="w-full max-w-lg hidden">
    <div class="bg-surface-container-high rough-border rough-shadow p-6 text-center mb-chunky-gap">
      <h2 class="font-headline-md text-2xl text-on-surface mb-unit">¿Lo logró?</h2>
      <div class="flex gap-chunky-gap justify-center">
        <button id="btn-voto-si"
                class="rough-border rough-shadow rough-button bg-green-700 text-white font-label-bold text-xl px-8 py-4 uppercase">
          👍 SÍ
        </button>
        <button id="btn-voto-no"
                class="rough-border rough-shadow rough-button bg-error-container text-on-error-container font-label-bold text-xl px-8 py-4 uppercase">
          👎 NO
        </button>
      </div>
    </div>

    <div class="bg-surface-container-high rough-border p-4">
      <div class="flex items-center justify-between mb-unit">
        <span class="font-label-bold text-on-surface-variant">VOTOS</span>
        <span id="vote-count" class="font-label-bold text-primary-container">0/0</span>
      </div>
      <div class="w-full h-6 bg-surface-container-lowest rough-border overflow-hidden">
        <div id="vote-bar" class="bar-fill h-full" style="width: 0%;"></div>
      </div>
    </div>
  </div>

  <div id="result-section" class="w-full max-w-lg hidden">
    <div class="bg-surface-container-high rough-border rough-shadow-lg p-8 text-center">
      <span id="result-icon" class="text-7xl mb-unit block">—</span>
      <h2 id="result-text" class="font-headline-md text-2xl text-on-surface">—</h2>
      <p id="result-detail" class="font-body-sm text-on-surface-variant mt-unit">—</p>
    </div>
  </div>

</main>

<%- include('partials/footer') %>

<script src="/socket.io/socket.io.js"></script>
<script>
(function() {
  const socket = io();
  const playerName = document.getElementById('player-name');
  const retoText = document.getElementById('reto-text');
  const acceptRejectSection = document.getElementById('accept-reject-section');
  const votingSection = document.getElementById('voting-section');
  const resultSection = document.getElementById('result-section');
  const btnAceptar = document.getElementById('btn-aceptar');
  const btnRechazar = document.getElementById('btn-rechazar');
  const btnVotoSi = document.getElementById('btn-voto-si');
  const btnVotoNo = document.getElementById('btn-voto-no');
  const voteCount = document.getElementById('vote-count');
  const voteBar = document.getElementById('vote-bar');
  const resultIcon = document.getElementById('result-icon');
  const resultText = document.getElementById('result-text');
  const resultDetail = document.getElementById('result-detail');

  let isMyTurn = false;
  let hasVoted = false;

  socket.on('reto_assigned', function(data) {
    playerName.textContent = data.playerName;
    retoText.textContent = data.reto;
    isMyTurn = data.isMyTurn;
    resultSection.classList.add('hidden');
    votingSection.classList.add('hidden');

    if (isMyTurn) {
      acceptRejectSection.classList.remove('hidden');
    } else {
      acceptRejectSection.classList.add('hidden');
      votingSection.classList.remove('hidden');
      hasVoted = false;
      btnVotoSi.disabled = false;
      btnVotoNo.disabled = false;
    }
  });

  btnAceptar.addEventListener('click', function() {
    acceptRejectSection.classList.add('hidden');
    votingSection.classList.remove('hidden');
    socket.emit('reto_response', { accepted: true });
  });

  btnRechazar.addEventListener('click', function() {
    acceptRejectSection.classList.add('hidden');
    socket.emit('reto_response', { accepted: false });
  });

  btnVotoSi.addEventListener('click', function() {
    if (hasVoted) return;
    hasVoted = true;
    btnVotoSi.disabled = true;
    btnVotoNo.disabled = true;
    btnVotoSi.classList.add('ring-4', 'ring-primary-container');
    socket.emit('reto_vote', { vote: true });
  });

  btnVotoNo.addEventListener('click', function() {
    if (hasVoted) return;
    hasVoted = true;
    btnVotoSi.disabled = true;
    btnVotoNo.disabled = true;
    btnVotoNo.classList.add('ring-4', 'ring-primary-container');
    socket.emit('reto_vote', { vote: false });
  });

  socket.on('reto_vote_update', function(data) {
    voteCount.textContent = data.voted + '/' + data.total;
    const pct = data.total > 0 ? Math.round((data.si / data.total) * 100) : 0;
    voteBar.style.width = pct + '%';
  });

  socket.on('reto_result', function(data) {
    votingSection.classList.add('hidden');
    resultSection.classList.remove('hidden');
    if (data.success) {
      resultIcon.textContent = '🎉';
      resultText.textContent = '¡LO LOGRÓ!';
      resultText.className = 'font-headline-md text-2xl text-green-400';
    } else {
      resultIcon.textContent = '😅';
      resultText.textContent = 'NO LO LOGRÓ';
      resultText.className = 'font-headline-md text-2xl text-error';
    }
    resultDetail.textContent = data.si + ' sí / ' + data.no + ' no';
  });

  socket.on('next_round', function() {
    resultSection.classList.add('hidden');
    acceptRejectSection.classList.add('hidden');
    votingSection.classList.add('hidden');
    retoText.textContent = 'Esperando siguiente ronda...';
    playerName.textContent = '—';
  });
})();
</script>

</body>
</html>