<!DOCTYPE html>
<html class="dark" lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RondaCero - Canje de Premios</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;1,400;1,500&family=Lexend:wght@600&family=Spline+Sans:wght@700;800&display=swap" rel="stylesheet"/>
  <script>
  tailwind.config={darkMode:"class",theme:{extend:{colors:{"surface-bright":"#303b41","surface-dim":"#0a151a","secondary-fixed-dim":"#5bd5fc","background":"#0a151a","inverse-surface":"#d8e4ec","on-surface":"#d8e4ec","inverse-primary":"#745c00","surface":"#0a151a","surface-container-low":"#121d23","on-primary-container":"#725a00","on-tertiary-container":"#b8005e","secondary-container":"#00a3c8","primary-container":"#ffd23f","on-error":"#690005","surface-container-highest":"#2b363d","primary-fixed":"#ffe089","surface-variant":"#2b363d","on-secondary-container":"#003341","tertiary-fixed-dim":"#ffb1c6","on-error-container":"#ffdad6","on-surface-variant":"#d1c5ad","error-container":"#93000a","secondary-fixed":"#b7eaff","outline-variant":"#4d4634","error":"#ffb4ab","surface-container-lowest":"#051015","inverse-on-surface":"#273238","on-tertiary-fixed":"#3f001c","tertiary-container":"#ffc9d6","on-secondary-fixed":"#001f28","on-tertiary":"#650031","on-primary-fixed":"#241a00","primary-fixed-dim":"#edc22e","tertiary":"#fff0f2","surface-tint":"#edc22e","surface-container-high":"#202b32","on-secondary-fixed-variant":"#004e61","secondary":"#5bd5fc","on-primary-fixed-variant":"#574500","on-secondary":"#003543","on-primary":"#3d2f00","primary":"#fff2d7","outline":"#9a907a","on-background":"#d8e4ec","surface-container":"#162127","tertiary-fixed":"#ffd9e1","on-tertiary-fixed-variant":"#8e0048"},fontFamily:{"body-sm":["Be Vietnam Pro"],"body-lg":["Be Vietnam Pro"],"headline-xl":["Spline Sans"],"label-bold":["Lexend"],"bilingual-sub":["Be Vietnam Pro"],"headline-md":["Spline Sans"]},fontSize:{"body-sm":["14px",{"lineHeight":"1.5","fontWeight":"400"}],"body-lg":["18px",{"lineHeight":"1.6","fontWeight":"400"}],"headline-xl":["48px",{"lineHeight":"1.1","letterSpacing":"-0.02em","fontWeight":"800"}],"label-bold":["14px",{"lineHeight":"1.0","fontWeight":"600"}],"bilingual-sub":["12px",{"lineHeight":"1.2","fontWeight":"500"}],"headline-md":["32px",{"lineHeight":"1.2","fontWeight":"700"}]},borderRadius:{"DEFAULT":"0.25rem","lg":"0.5rem","xl":"0.75rem","full":"9999px"},spacing:{"margin":"24px","chunky-gap":"12px","gutter":"16px","container-max":"1200px","unit":"8px"}}}}
  </script>
  <style>
    .rough-border{border:4px solid #000;border-radius:4px 8px 3px 6px}
    .rough-shadow{box-shadow:4px 4px 0px 0px rgba(0,0,0,1)}
    .rough-shadow-lg{box-shadow:8px 8px 0px 0px rgba(0,0,0,1)}
    .rough-button:active{box-shadow:none;transform:translate(4px,4px)}
    .paper-stack{position:relative}
    .paper-stack::before{content:'';position:absolute;top:4px;left:-4px;right:4px;bottom:-4px;border:4px solid #000;background:#2b363d;z-index:-1;transform:rotate(-1deg)}
    .error-msg{background:#93000a;color:#ffdad6;border:2px solid black}
    ::selection{background:#ffd23f;color:black}
    .prize-card{transition:transform 0.2s}
    .prize-card:hover{transform:rotate(0deg) scale(1.03)!important}
    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:50}
  </style>
</head>
<body class="bg-background text-on-background min-h-screen font-body-lg">

<%- include('partials/header') %>

<main class="flex-1 px-gutter py-margin max-w-container-max mx-auto w-full">

  <div class="text-center mb-margin">
    <div class="inline-block bg-surface-container-high rough-border rough-shadow-lg px-8 py-4">
      <span class="text-4xl align-middle mr-2">🪙</span>
      <span class="font-headline-xl text-headline-xl text-primary-fixed" id="balance-display">0</span>
      <p class="font-label-bold text-on-surface-variant mt-1">MONEDAS DISPONIBLES</p>
    </div>
  </div>

  <h2 class="font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider mb-chunky-gap">
    <span class="material-symbols-outlined align-middle mr-1">redeem</span>Catálogo de Premios
  </h2>

  <div id="prizes-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-margin mb-margin">
    <div class="bg-surface-container-high rough-border p-6 text-center">
      <p class="font-body-sm text-on-surface-variant">Cargando premios...</p>
    </div>
  </div>

</main>

<div id="confirm-modal" class="modal-overlay hidden">
  <div class="bg-surface-container-high rough-border rough-shadow-lg p-8 max-w-md w-full mx-4" style="transform:rotate(-0.5deg)">
    <h3 class="font-headline-md text-xl text-primary-container mb-unit">CONFIRMAR CANJE</h3>
    <p class="font-body-lg text-on-surface mb-margin" id="modal-text">
      ¿Canjear premio por X monedas?
    </p>
    <div class="flex gap-chunky-gap justify-end">
      <button id="modal-cancel" class="rough-border rough-shadow rough-button bg-surface-container-lowest text-on-surface font-label-bold px-5 py-2 uppercase">
        Cancelar
      </button>
      <button id="modal-confirm" class="rough-border rough-shadow rough-button bg-primary-container text-on-primary-container font-label-bold px-5 py-2 uppercase">
        Confirmar
      </button>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<script>
(function() {
  var prizesGrid = document.getElementById('prizes-grid');
  var balanceDisplay = document.getElementById('balance-display');
  var confirmModal = document.getElementById('confirm-modal');
  var modalText = document.getElementById('modal-text');
  var modalCancel = document.getElementById('modal-cancel');
  var modalConfirm = document.getElementById('modal-confirm');
  var selectedPrize = null;
  var currentBalance = 0;

  function loadBalance() {
    fetch('/api/billetera')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        currentBalance = data.saldo || 0;
        balanceDisplay.textContent = currentBalance;
      })
      .catch(function() { balanceDisplay.textContent = '—'; });
  }

  function loadPrizes() {
    fetch('/api/premios')
      .then(function(r) { return r.json(); })
      .then(function(premios) {
        if (!premios || premios.length === 0) {
          prizesGrid.innerHTML = '<div class="bg-surface-container-high rough-border p-6 text-center col-span-full"><p class="font-body-sm text-on-surface-variant">No hay premios disponibles</p></div>';
          return;
        }
        prizesGrid.innerHTML = premios.map(function(p, i) {
          var rotations = [-1.5, 0.8, -0.5, 1.2, -0.8, 0.5];
          var rot = rotations[i % rotations.length];
          var canAfford = currentBalance >= p.costo_monedas;
          var inStock = p.stock > 0;
          var disabled = !canAfford || !inStock;
          return '<div class="prize-card paper-stack bg-surface-container-high rough-border rough-shadow p-6" style="transform:rotate(' + rot + 'deg)">' +
            '<h3 class="font-headline-md text-xl text-primary-container mb-1">' + p.nombre_premio + '</h3>' +
            '<p class="font-body-sm text-on-surface-variant mb-unit">' + (p.descripcion || 'Sin descripción') + '</p>' +
            '<div class="flex items-center justify-between mb-unit">' +
              '<span class="font-label-bold text-primary-container text-lg">🪙 ' + p.costo_monedas + '</span>' +
              '<span class="font-body-sm ' + (inStock ? 'text-secondary' : 'text-error') + '">Stock: ' + p.stock + '</span>' +
            '</div>' +
            '<button data-id="' + p.id_premio + '" data-name="' + p.nombre_premio + '" data-cost="' + p.costo_monedas + '"' +
              ' class="canje-btn w-full rough-border rough-shadow rough-button font-label-bold px-4 py-2 uppercase ' +
              (disabled ? 'bg-surface-variant text-on-surface-variant cursor-not-allowed opacity-50' : 'bg-primary-container text-on-primary-container') + '"' +
              (disabled ? ' disabled' : '') + '>' +
              (!inStock ? 'AGOTADO' : (!canAfford ? 'SALDO INSUFICIENTE' : 'CANJEAR')) +
            '</button>' +
          '</div>';
        }).join('');

        document.querySelectorAll('.canje-btn:not([disabled])').forEach(function(btn) {
          btn.addEventListener('click', function() {
            selectedPrize = { id: btn.dataset.id, name: btn.dataset.name, cost: parseInt(btn.dataset.cost) };
            modalText.textContent = '¿Canjear ' + selectedPrize.name + ' por ' + selectedPrize.cost + ' monedas?';
            confirmModal.classList.remove('hidden');
          });
        });
      })
      .catch(function() {
        prizesGrid.innerHTML = '<div class="bg-surface-container-high rough-border p-6 text-center col-span-full error-msg"><p class="font-body-sm">Error al cargar premios</p></div>';
      });
  }

  modalCancel.addEventListener('click', function() {
    confirmModal.classList.add('hidden');
    selectedPrize = null;
  });

  modalConfirm.addEventListener('click', function() {
    if (!selectedPrize) return;
    modalConfirm.disabled = true;
    modalConfirm.textContent = 'Canjeando...';
    fetch('/api/canje', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id_premio: selectedPrize.id })
    })
    .then(function(r) {
      if (!r.ok) throw new Error('Error en canje');
      return r.json();
    })
    .then(function(data) {
      confirmModal.classList.add('hidden');
      window.location.href = '/canje/qr?id=' + (data.id_canje || '');
    })
    .catch(function(err) {
      alert('Error al canjear: ' + err.message);
      modalConfirm.disabled = false;
      modalConfirm.textContent = 'Confirmar';
    });
  });

  confirmModal.addEventListener('click', function(e) {
    if (e.target === confirmModal) {
      confirmModal.classList.add('hidden');
      selectedPrize = null;
    }
  });

  loadBalance();
  setTimeout(loadPrizes, 300);
})();
</script>

</body>
</html>