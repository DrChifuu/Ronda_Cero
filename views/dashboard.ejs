<!DOCTYPE html>
<html lang="es" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RondaCero &mdash; Dashboard</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;1,400;1,500&family=Lexend:wght@600&family=Spline+Sans:wght@700;800&display=swap" rel="stylesheet"/>
  <script>
tailwind.config = {
  darkMode: "class",
  theme: {
    extend: {
      colors: {
        "surface-bright": "#303b41", "surface-dim": "#0a151a", "secondary-fixed-dim": "#5bd5fc",
        "background": "#0a151a", "inverse-surface": "#d8e4ec", "on-surface": "#d8e4ec",
        "inverse-primary": "#745c00", "surface": "#0a151a", "surface-container-low": "#121d23",
        "on-primary-container": "#725a00", "on-tertiary-container": "#b8005e",
        "secondary-container": "#00a3c8", "primary-container": "#ffd23f", "on-error": "#690005",
        "surface-container-highest": "#2b363d", "primary-fixed": "#ffe089",
        "surface-variant": "#2b363d", "on-secondary-container": "#003341",
        "tertiary-fixed-dim": "#ffb1c6", "on-error-container": "#ffdad6",
        "on-surface-variant": "#d1c5ad", "error-container": "#93000a",
        "secondary-fixed": "#b7eaff", "outline-variant": "#4d4634", "error": "#ffb4ab",
        "surface-container-lowest": "#051015", "inverse-on-surface": "#273238",
        "on-tertiary-fixed": "#3f001c", "tertiary-container": "#ffc9d6",
        "on-secondary-fixed": "#001f28", "on-tertiary": "#650031",
        "on-primary-fixed": "#241a00", "primary-fixed-dim": "#edc22e",
        "tertiary": "#fff0f2", "surface-tint": "#edc22e",
        "surface-container-high": "#202b32", "on-secondary-fixed-variant": "#004e61",
        "secondary": "#5bd5fc", "on-primary-fixed-variant": "#574500",
        "on-secondary": "#003543", "on-primary": "#3d2f00", "primary": "#fff2d7",
        "outline": "#9a907a", "on-background": "#d8e4ec", "surface-container": "#162127",
        "tertiary-fixed": "#ffd9e1", "on-tertiary-fixed-variant": "#8e0048"
      },
      fontFamily: {
        "body-sm": ["Be Vietnam Pro"], "body-lg": ["Be Vietnam Pro"],
        "headline-xl": ["Spline Sans"], "label-bold": ["Lexend"],
        "bilingual-sub": ["Be Vietnam Pro"], "headline-md": ["Spline Sans"]
      },
      fontSize: {
        "body-sm": ["14px", { "lineHeight": "1.5", "fontWeight": "400" }],
        "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
        "headline-xl": ["48px", { "lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "800" }],
        "label-bold": ["14px", { "lineHeight": "1.0", "fontWeight": "600" }],
        "bilingual-sub": ["12px", { "lineHeight": "1.2", "fontWeight": "500" }],
        "headline-md": ["32px", { "lineHeight": "1.2", "fontWeight": "700" }]
      },
      borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
      spacing: { "margin": "24px", "chunky-gap": "12px", "gutter": "16px", "container-max": "1200px", "unit": "8px" }
    }
  }
}
  </script>
  <style>
    .rough-border { border: 4px solid #000; border-radius: 4px 8px 3px 6px; }
    .rough-shadow { box-shadow: 4px 4px 0px 0px rgba(0,0,0,1); }
    .rough-shadow-lg { box-shadow: 8px 8px 0px 0px rgba(0,0,0,1); }
    .rough-button:active { box-shadow: none; transform: translate(4px, 4px); }
    .paper-stack { position: relative; }
    .paper-stack::before { content: ''; position: absolute; top: 4px; left: -4px; right: 4px; bottom: -4px; border: 4px solid #000; background: #2b363d; z-index: -1; transform: rotate(-1deg); }
    .error-msg { background: #93000a; color: #ffdad6; border: 2px solid black; }
    .game-card { transition: transform 0.3s; }
    .game-card:hover { transform: rotate(0deg) scale(1.05) !important; }
    ::selection { background: #ffd23f; color: black; }
  </style>
</head>
<body class="bg-background text-on-surface min-h-screen flex flex-col">

  <%- include('partials/header') %>

  <main class="flex-1 px-gutter py-margin max-w-container-max mx-auto w-full">

    <div class="flex items-center justify-between mb-margin">
      <div class="flex items-center gap-chunky-gap">
        <span class="text-5xl"><%= avatar %></span>
        <div>
          <h1 class="font-headline-md text-headline-md text-primary-container"><%= playerName %></h1>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Bienvenido de vuelta</p>
        </div>
      </div>
      <a href="/auth/logout"
         class="rough-border rough-shadow rough-button bg-error-container text-on-error-container font-label-bold px-4 py-2 uppercase">
        <span class="material-symbols-outlined align-middle mr-1">logout</span>Salir
      </a>
    </div>

    <section class="mb-margin">
      <h2 class="font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider mb-chunky-gap">
        <span class="material-symbols-outlined align-middle mr-1">sports_esports</span>Minijuegos
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-margin">

        <a href="/crear-sala" class="game-card paper-stack bg-surface-container-high rough-border rough-shadow p-6 block" style="transform: rotate(-2deg);">
          <div class="text-5xl mb-unit">🍺</div>
          <h3 class="font-headline-md text-xl text-primary-container mb-1">DRINK PARTY</h3>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Trivia, retos, dados y más</p>
          <span class="inline-block mt-unit font-label-bold text-bilingual-sub bg-primary-container text-on-primary-container px-2 py-1 rough-border">
            JUGAR AHORA
          </span>
        </a>

        <div class="game-card paper-stack bg-surface-container-high rough-border rough-shadow p-6 opacity-60 cursor-not-allowed" style="transform: rotate(1deg);">
          <div class="text-5xl mb-unit">🎤</div>
          <h3 class="font-headline-md text-xl text-on-surface mb-1">KARAOKE PARTY</h3>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Batallas musicales y karaoke</p>
          <span class="inline-block mt-unit font-label-bold text-bilingual-sub bg-surface-variant text-on-surface-variant px-2 py-1 rough-border">
            PRÓXIMAMENTE
          </span>
        </div>

        <div class="game-card paper-stack bg-surface-container-high rough-border rough-shadow p-6 opacity-60 cursor-not-allowed" style="transform: rotate(-1.5deg);">
          <div class="text-5xl mb-unit">🎭</div>
          <h3 class="font-headline-md text-xl text-on-surface mb-1">SOCIAL PARTY</h3>
          <p class="font-body-sm text-body-sm text-on-surface-variant">¿Quién es más probable? y más</p>
          <span class="inline-block mt-unit font-label-bold text-bilingual-sub bg-surface-variant text-on-surface-variant px-2 py-1 rough-border">
            PRÓXIMAMENTE
          </span>
        </div>

        <div class="game-card paper-stack bg-surface-container-high rough-border rough-shadow p-6 opacity-60 cursor-not-allowed" style="transform: rotate(2deg);">
          <div class="text-5xl mb-unit">🏆</div>
          <h3 class="font-headline-md text-xl text-on-surface mb-1">TEAM PARTY</h3>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Escape express y debates</p>
          <span class="inline-block mt-unit font-label-bold text-bilingual-sub bg-surface-variant text-on-surface-variant px-2 py-1 rough-border">
            PRÓXIMAMENTE
          </span>
        </div>
      </div>
    </section>

    <section class="mb-margin">
      <h2 class="font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider mb-chunky-gap">
        <span class="material-symbols-outlined align-middle mr-1">apps</span>Accesos Rápidos
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-chunky-gap">

        <a href="/canje" class="game-card bg-surface-container rough-border rough-shadow p-5 flex items-center gap-chunky-gap" style="transform: rotate(0.5deg);">
          <span class="material-symbols-outlined text-4xl text-primary-container">redeem</span>
          <div>
            <h3 class="font-label-bold text-lg text-primary-container">CANJEAR PREMIOS</h3>
            <p class="font-body-sm text-body-sm text-on-surface-variant">Revisa el catálogo de premios disponibles</p>
          </div>
        </a>

        <a href="/perfil" class="game-card bg-surface-container rough-border rough-shadow p-5 flex items-center gap-chunky-gap" style="transform: rotate(-0.5deg);">
          <span class="material-symbols-outlined text-4xl text-secondary">person</span>
          <div>
            <h3 class="font-label-bold text-lg text-secondary">MI PERFIL</h3>
            <p class="font-body-sm text-body-sm text-on-surface-variant">Estadísticas y configuración</p>
          </div>
        </a>
      </div>
    </section>

    <section>
      <h2 class="font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wider mb-chunky-gap">
        <span class="material-symbols-outlined align-middle mr-1">bar_chart</span>Estadísticas
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-chunky-gap">

        <div class="bg-surface-container-high rough-border rough-shadow p-4 text-center">
          <span class="material-symbols-outlined text-3xl text-primary-container">casino</span>
          <p class="font-headline-md text-2xl text-primary-container mt-1">0</p>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Partidas Jugadas</p>
        </div>

        <div class="bg-surface-container-high rough-border rough-shadow p-4 text-center">
          <span class="material-symbols-outlined text-3xl text-secondary">monetization_on</span>
          <p class="font-headline-md text-2xl text-secondary mt-1">0</p>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Puntos Totales</p>
        </div>

        <div class="bg-surface-container-high rough-border rough-shadow p-4 text-center">
          <span class="material-symbols-outlined text-3xl text-tertiary">emoji_events</span>
          <p class="font-headline-md text-2xl text-tertiary mt-1">0</p>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Victorias</p>
        </div>

        <div class="bg-surface-container-high rough-border rough-shadow p-4 text-center">
          <span class="material-symbols-outlined text-3xl text-error">redeem</span>
          <p class="font-headline-md text-2xl text-error mt-1">0</p>
          <p class="font-body-sm text-body-sm text-on-surface-variant">Premios Canjeados</p>
        </div>
      </div>
    </section>

  </main>

  <%- include('partials/footer') %>

</body>
</html>
