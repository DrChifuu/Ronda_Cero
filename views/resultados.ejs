<!DOCTYPE html>
<html class="dark" lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RondaCero - Resultados</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;1,400;1,500&family=Lexend:wght@600&family=Spline+Sans:wght@700;800&display=swap" rel="stylesheet"/>
  <script>
  tailwind.config={darkMode:"class",theme:{extend:{colors:{"surface-bright":"#303b41","surface-dim":"#0a151a","secondary-fixed-dim":"#5bd5fc","background":"#0a151a","inverse-surface":"#d8e4ec","on-surface":"#d8e4ec","inverse-primary":"#745c00","surface":"#0a151a","surface-container-low":"#121d23","on-primary-container":"#725a00","on-tertiary-container":"#b8005e","secondary-container":"#00a3c8","primary-container":"#ffd23f","on-error":"#690005","surface-container-highest":"#2b363d","primary-fixed":"#ffe089","surface-variant":"#2b363d","on-secondary-container":"#003341","tertiary-fixed-dim":"#ffb1c6","on-error-container":"#ffdad6","on-surface-variant":"#d1c5ad","error-container":"#93000a","secondary-fixed":"#b7eaff","outline-variant":"#4d4634","error":"#ffb4ab","surface-container-lowest":"#051015","inverse-on-surface":"#273238","on-tertiary-fixed":"#3f001c","tertiary-container":"#ffc9d6","on-secondary-fixed":"#001f28","on-tertiary":"#650031","on-primary-fixed":"#241a00","primary-fixed-dim":"#edc22e","tertiary":"#fff0f2","surface-tint":"#edc22e","surface-container-high":"#202b32","on-secondary-fixed-variant":"#004e61","secondary":"#5bd5fc","on-primary-fixed-variant":"#574500","on-secondary":"#003543","on-primary":"#3d2f00","primary":"#fff2d7","outline":"#9a907a","on-background":"#d8e4ec","surface-container":"#162127","tertiary-fixed":"#ffd9e1","on-tertiary-fixed-variant":"#8e0048"},fontFamily:{"body-sm":["Be Vietnam Pro"],"body-lg":["Be Vietnam Pro"],"headline-xl":["Spline Sans"],"label-bold":["Lexend"],"bilingual-sub":["Be Vietnam Pro"],"headline-md":["Spline Sans"]},fontSize:{"body-sm":["14px",{"lineHeight":"1.5","fontWeight":"400"}],"body-lg":["18px",{"lineHeight":"1.6","fontWeight":"400"}],"headline-xl":["48px",{"lineHeight":"1.1","letterSpacing":"-0.02em","fontWeight":"800"}],"label-bold":["14px",{"lineHeight":"1.0","fontWeight":"600"}],"bilingual-sub":["12px",{"lineHeight":"1.2","fontWeight":"500"}],"headline-md":["32px",{"lineHeight":"1.2","fontWeight":"700"}]},borderRadius:{"DEFAULT":"0.25rem","lg":"0.5rem","xl":"0.75rem","full":"9999px"},spacing:{"margin":"24px","chunky-gap":"12px","gutter":"16px","container-max":"1200px","unit":"8px"}}}}
  </script>
  <style>
    .rough-border{border:4px solid #000;border-radius:4px 8px 3px 6px}
    .rough-shadow{box-shadow:4px 4px 0px 0px rgba(0,0,0,1)}
    .rough-shadow-lg{box-shadow:8px 8px 0px 0px rgba(0,0,0,1)}
    .rough-button:active{box-shadow:none;transform:translate(4px,4px)}
    .paper-stack{position:relative}
    .paper-stack::before{content:'';position:absolute;top:4px;left:-4px;right:4px;bottom:-4px;border:4px solid #000;background:#2b363d;z-index:-1;transform:rotate(-1deg)}
    .error-msg{background:#93000a;color:#ffdad6;border:2px solid black}
    ::selection{background:#ffd23f;color:black}
    .podium-col{display:flex;flex-direction:column;align-items:center;justify-content:flex-end}
    .podium-gold{height:200px}
    .podium-silver{height:150px}
    .podium-bronze{height:120px}
    .confetti-piece{position:fixed;top:-20px;width:12px;height:12px;border:2px solid #000;animation:confettiFall linear forwards}
    @keyframes confettiFall{0%{transform:translateY(0) rotate(0deg);opacity:1}100%{transform:translateY(110vh) rotate(720deg);opacity:0}}
  </style>
</head>
<body class="bg-background text-on-background min-h-screen font-body-lg">

<%- include('partials/header') %>

<main class="flex-1 px-gutter py-margin max-w-container-max mx-auto w-full">

  <div class="text-center mb-margin">
    <h1 class="font-headline-xl text-headline-xl text-primary-container">🏆 RESULTADOS</h1>
    <p class="font-body-sm text-on-surface-variant mt-unit">Sala: <span class="font-label-bold text-secondary"><%= typeof codigo !== 'undefined' ? codigo : '—' %></span></p>
  </div>

  <div class="flex items-end justify-center gap-chunky-gap mb-margin">
    <div class="podium-col w-1/3">
      <div class="text-center mb-unit">
        <span class="text-5xl block" id="silver-avatar"></span>
        <p class="font-label-bold text-on-surface" id="silver-name">—</p>
        <p class="font-headline-md text-xl text-secondary" id="silver-score">0 pts</p>
      </div>
      <div class="podium-silver w-full bg-surface-container-high rough-border rough-shadow flex items-center justify-center">
        <span class="font-headline-xl text-5xl">🥈</span>
      </div>
    </div>
    <div class="podium-col w-1/3">
      <div class="text-center mb-unit">
        <span class="text-5xl block" id="gold-avatar"></span>
        <p class="font-label-bold text-primary-container" id="gold-name">—</p>
        <p class="font-headline-md text-2xl text-primary-container" id="gold-score">0 pts</p>
      </div>
      <div class="podium-gold w-full bg-primary-container rough-border rough-shadow-lg flex items-center justify-center">
        <span class="font-headline-xl text-6xl">🥇</span>
      </div>
    </div>
    <div class="podium-col w-1/3">
      <div class="text-center mb-unit">
        <span class="text-5xl block" id="bronze-avatar"></span>
        <p class="font-label-bold text-on-surface" id="bronze-name">—</p>
        <p class="font-headline-md text-xl text-tertiary-fixed-dim" id="bronze-score">0 pts</p>
      </div>
      <div class="podium-bronze w-full bg-surface-container-high rough-border rough-shadow flex items-center justify-center">
        <span class="font-headline-xl text-5xl">🥉</span>
      </div>
    </div>
  </div>

  <div class="bg-surface-container-high rough-border rough-shadow mb-margin overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b-4 border-black bg-surface-container-lowest">
          <th class="font-label-bold text-on-surface-variant px-4 py-3 text-left">#</th>
          <th class="font-label-bold text-on-surface-variant px-4 py-3 text-left">Jugador</th>
          <th class="font-label-bold text-on-surface-variant px-4 py-3 text-center">Pts</th>
          <th class="font-label-bold text-on-surface-variant px-4 py-3 text-center">Correctas</th>
          <th class="font-label-bold text-on-surface-variant px-4 py-3 text-center">Tragos</th>
          <th class="font-label-bold text-on-surface-variant px-4 py-3 text-center">Monedas</th>
        </tr>
      </thead>
      <tbody id="ranking-body">
      </tbody>
    </table>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-chunky-gap mb-margin">
    <div class="bg-surface-container-high rough-border rough-shadow p-4 flex items-center gap-chunky-gap">
      <span class="material-symbols-outlined text-3xl text-secondary">speed</span>
      <div>
        <p class="font-label-bold text-on-surface-variant">RONDA MÁS RÁPIDA</p>
        <p class="font-headline-md text-xl text-secondary" id="fastest-round">—</p>
      </div>
    </div>
    <div class="bg-surface-container-high rough-border rough-shadow p-4 flex items-center gap-chunky-gap">
      <span class="material-symbols-outlined text-3xl text-primary-container">sports_esports</span>
      <div>
        <p class="font-label-bold text-on-surface-variant">MODO MÁS JUGADO</p>
        <p class="font-headline-md text-xl text-primary-container" id="most-played">—</p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-chunky-gap">
    <a href="/crear-sala" class="rough-border rough-shadow rough-button bg-primary-container text-on-primary-container font-label-bold px-4 py-3 text-center uppercase block">
      <span class="material-symbols-outlined align-middle mr-1">replay</span>Jugar Otra Vez
    </a>
    <a href="/gastos" class="rough-border rough-shadow rough-button bg-secondary-container text-on-secondary-container font-label-bold px-4 py-3 text-center uppercase block">
      <span class="material-symbols-outlined align-middle mr-1">receipt_long</span>Dividir Gastos
    </a>
    <a href="/canje" class="rough-border rough-shadow rough-button bg-tertiary-container text-on-tertiary-container font-label-bold px-4 py-3 text-center uppercase block">
      <span class="material-symbols-outlined align-middle mr-1">redeem</span>Canjear Premios
    </a>
    <a href="/" class="rough-border rough-shadow rough-button bg-surface-container-high text-on-surface font-label-bold px-4 py-3 text-center uppercase block">
      <span class="material-symbols-outlined align-middle mr-1">home</span>Inicio
    </a>
  </div>

</main>

<%- include('partials/footer') %>

<script>
(function() {
  var results = <%- typeof resultados !== 'undefined' ? JSON.stringify(resultados) : 'null' %>;

  function populatePodium(ranking) {
    if (!ranking || ranking.length === 0) return;
    if (ranking[0]) {
      document.getElementById('gold-avatar').textContent = ranking[0].avatar || '😎';
      document.getElementById('gold-name').textContent = ranking[0].nombre;
      document.getElementById('gold-score').textContent = ranking[0].puntos + ' pts';
    }
    if (ranking[1]) {
      document.getElementById('silver-avatar').textContent = ranking[1].avatar || '😎';
      document.getElementById('silver-name').textContent = ranking[1].nombre;
      document.getElementById('silver-score').textContent = ranking[1].puntos + ' pts';
    }
    if (ranking[2]) {
      document.getElementById('bronze-avatar').textContent = ranking[2].avatar || '😎';
      document.getElementById('bronze-name').textContent = ranking[2].nombre;
      document.getElementById('bronze-score').textContent = ranking[2].puntos + ' pts';
    }
  }

  function populateTable(ranking) {
    var tbody = document.getElementById('ranking-body');
    if (!ranking) return;
    tbody.innerHTML = ranking.map(function(p, i) {
      var rowClass = i < 3 ? 'bg-surface-container' : 'bg-surface-container-high';
      return '<tr class="' + rowClass + ' border-b-2 border-black">' +
        '<td class="px-4 py-3 font-label-bold text-primary-container">' + (i + 1) + '</td>' +
        '<td class="px-4 py-3"><span class="mr-2">' + (p.avatar || '😎') + '</span><span class="font-body-sm text-on-surface">' + p.nombre + '</span></td>' +
        '<td class="px-4 py-3 text-center font-label-bold text-primary-container">' + (p.puntos || 0) + '</td>' +
        '<td class="px-4 py-3 text-center font-body-sm text-on-surface">' + (p.correctas || 0) + '</td>' +
        '<td class="px-4 py-3 text-center font-body-sm text-on-surface">' + (p.tragos || 0) + '</td>' +
        '<td class="px-4 py-3 text-center font-label-bold text-secondary">' + (p.monedas || 0) + '</td>' +
        '</tr>';
    }).join('');
  }

  function populateStats(stats) {
    if (!stats) return;
    document.getElementById('fastest-round').textContent = stats.rondaRapida || '—';
    document.getElementById('most-played').textContent = stats.modoMasJugado || '—';
  }

  function spawnConfetti() {
    var colors = ['#ffd23f','#5bd5fc','#ffb1c6','#ffdad6','#b7eaff','#edc22e'];
    for (var i = 0; i < 60; i++) {
      var piece = document.createElement('div');
      piece.className = 'confetti-piece';
      piece.style.left = Math.random() * 100 + 'vw';
      piece.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
      piece.style.animationDuration = (2 + Math.random() * 3) + 's';
      piece.style.animationDelay = (Math.random() * 2) + 's';
      document.body.appendChild(piece);
      setTimeout(function(el) { el.remove(); }.bind(null, piece), 6000);
    }
  }

  if (results) {
    populatePodium(results.ranking);
    populateTable(results.ranking);
    populateStats(results.stats);
    spawnConfetti();
  }
})();
</script>

</body>
</html>