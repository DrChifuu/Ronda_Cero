<!DOCTYPE html>
<html class="dark" lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RondaCero - QR Canje</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;1,400;1,500&family=Lexend:wght@600&family=Spline+Sans:wght@700;800&display=swap" rel="stylesheet"/>
  <script>
  tailwind.config={darkMode:"class",theme:{extend:{colors:{"surface-bright":"#303b41","surface-dim":"#0a151a","secondary-fixed-dim":"#5bd5fc","background":"#0a151a","inverse-surface":"#d8e4ec","on-surface":"#d8e4ec","inverse-primary":"#745c00","surface":"#0a151a","surface-container-low":"#121d23","on-primary-container":"#725a00","on-tertiary-container":"#b8005e","secondary-container":"#00a3c8","primary-container":"#ffd23f","on-error":"#690005","surface-container-highest":"#2b363d","primary-fixed":"#ffe089","surface-variant":"#2b363d","on-secondary-container":"#003341","tertiary-fixed-dim":"#ffb1c6","on-error-container":"#ffdad6","on-surface-variant":"#d1c5ad","error-container":"#93000a","secondary-fixed":"#b7eaff","outline-variant":"#4d4634","error":"#ffb4ab","surface-container-lowest":"#051015","inverse-on-surface":"#273238","on-tertiary-fixed":"#3f001c","tertiary-container":"#ffc9d6","on-secondary-fixed":"#001f28","on-tertiary":"#650031","on-primary-fixed":"#241a00","primary-fixed-dim":"#edc22e","tertiary":"#fff0f2","surface-tint":"#edc22e","surface-container-high":"#202b32","on-secondary-fixed-variant":"#004e61","secondary":"#5bd5fc","on-primary-fixed-variant":"#574500","on-secondary":"#003543","on-primary":"#3d2f00","primary":"#fff2d7","outline":"#9a907a","on-background":"#d8e4ec","surface-container":"#162127","tertiary-fixed":"#ffd9e1","on-tertiary-fixed-variant":"#8e0048"},fontFamily:{"body-sm":["Be Vietnam Pro"],"body-lg":["Be Vietnam Pro"],"headline-xl":["Spline Sans"],"label-bold":["Lexend"],"bilingual-sub":["Be Vietnam Pro"],"headline-md":["Spline Sans"]},fontSize:{"body-sm":["14px",{"lineHeight":"1.5","fontWeight":"400"}],"body-lg":["18px",{"lineHeight":"1.6","fontWeight":"400"}],"headline-xl":["48px",{"lineHeight":"1.1","letterSpacing":"-0.02em","fontWeight":"800"}],"label-bold":["14px",{"lineHeight":"1.0","fontWeight":"600"}],"bilingual-sub":["12px",{"lineHeight":"1.2","fontWeight":"500"}],"headline-md":["32px",{"lineHeight":"1.2","fontWeight":"700"}]},borderRadius:{"DEFAULT":"0.25rem","lg":"0.5rem","xl":"0.75rem","full":"9999px"},spacing:{"margin":"24px","chunky-gap":"12px","gutter":"16px","container-max":"1200px","unit":"8px"}}}}
  </script>
  <style>
    .rough-border{border:4px solid #000;border-radius:4px 8px 3px 6px}
    .rough-shadow{box-shadow:4px 4px 0px 0px rgba(0,0,0,1)}
    .rough-shadow-lg{box-shadow:8px 8px 0px 0px rgba(0,0,0,1)}
    .rough-button:active{box-shadow:none;transform:translate(4px,4px)}
    .paper-stack{position:relative}
    .paper-stack::before{content:'';position:absolute;top:4px;left:-4px;right:4px;bottom:-4px;border:4px solid #000;background:#2b363d;z-index:-1;transform:rotate(-1deg)}
    .error-msg{background:#93000a;color:#ffdad6;border:2px solid black}
    ::selection{background:#ffd23f;color:black}
    .qr-box{background:white;padding:16px;display:inline-block;border:4px solid #000}
    .timer-warning{animation:pulse 1s infinite}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}
  </style>
</head>
<body class="bg-background text-on-background min-h-screen font-body-lg">

<%- include('partials/header') %>

<main class="flex-1 px-gutter py-margin max-w-container-max mx-auto w-full flex flex-col items-center justify-center">

  <div class="w-full max-w-md text-center">

    <div class="paper-stack bg-surface-container-high rough-border rough-shadow-lg p-8" style="transform:rotate(-0.3deg)">

      <span class="material-symbols-outlined text-5xl text-primary-container mb-unit">qr_code_2</span>
      <h1 class="font-headline-md text-headline-md text-primary-container mb-unit">TU CÓDIGO QR</h1>

      <div class="flex justify-center mb-margin">
        <div class="qr-box" id="qr-container">
          <div id="qr-code" style="width:220px;height:220px;display:flex;align-items:center;justify-content:center;background:#f0f0f0">
            <span class="font-body-sm text-gray-500">Generando QR...</span>
          </div>
        </div>
      </div>

      <div class="bg-surface-container-lowest rough-border p-4 mb-unit">
        <p class="font-label-bold text-primary-container text-lg" id="prize-name">—</p>
        <p class="font-body-sm text-on-surface-variant" id="local-name">—</p>
      </div>

      <div class="bg-surface-container-lowest rough-border p-4 mb-margin">
        <div class="flex items-center justify-center gap-unit">
          <span class="material-symbols-outlined text-error">timer</span>
          <span class="font-label-bold text-on-surface-variant">Este QR expira en</span>
        </div>
        <p id="countdown" class="font-headline-md text-2xl text-error mt-1">5:00</p>
      </div>

      <div class="bg-surface-container rough-border p-3 mb-margin">
        <p class="font-body-sm text-on-surface-variant">
          <span class="material-symbols-outlined align-middle text-secondary mr-1" style="font-size:18px">info</span>
          Muestra este código al administrador del local para canjear tu premio
        </p>
      </div>

      <a href="/" class="rough-border rough-shadow rough-button bg-surface-container-high text-on-surface font-label-bold px-6 py-3 uppercase inline-block">
        <span class="material-symbols-outlined align-middle mr-1">home</span>Volver al Inicio
      </a>

    </div>

  </div>

</main>

<%- include('partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
<script>
(function() {
  var countdownEl = document.getElementById('countdown');
  var prizeNameEl = document.getElementById('prize-name');
  var localNameEl = document.getElementById('local-name');
  var qrCodeEl = document.getElementById('qr-code');
  var totalSeconds = 300;
  var timerInterval;

  var params = new URLSearchParams(window.location.search);
  var canjeId = params.get('id');

  function startCountdown() {
    timerInterval = setInterval(function() {
      totalSeconds--;
      if (totalSeconds <= 0) {
        clearInterval(timerInterval);
        countdownEl.textContent = 'EXPIRADO';
        countdownEl.classList.add('timer-warning');
        qrCodeEl.innerHTML = '<span class="font-label-bold text-red-600">QR EXPIRADO</span>';
        return;
      }
      var min = Math.floor(totalSeconds / 60);
      var sec = totalSeconds % 60;
      countdownEl.textContent = min + ':' + (sec < 10 ? '0' : '') + sec;
      if (totalSeconds <= 60) {
        countdownEl.classList.add('timer-warning');
      }
    }, 1000);
  }

  function loadCanje() {
    if (!canjeId) {
      prizeNameEl.textContent = 'Sin datos de canje';
      qrCodeEl.innerHTML = '<span class="font-body-sm text-gray-500">No hay QR disponible</span>';
      return;
    }
    fetch('/api/canje/' + canjeId)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        prizeNameEl.textContent = data.nombre_premio || 'Premio';
        localNameEl.textContent = data.nombre_comercial || '';
        var qrData = data.qr_code || canjeId;
        qrCodeEl.innerHTML = '';
        if (typeof QRCode !== 'undefined') {
          QRCode.toCanvas(qrData, { width: 220, margin: 1 }, function(err, canvas) {
            if (err) {
              qrCodeEl.innerHTML = '<div style="width:220px;height:220px;display:flex;align-items:center;justify-content:center;font-size:12px;color:#666">' + qrData + '</div>';
            } else {
              qrCodeEl.appendChild(canvas);
            }
          });
        }
        startCountdown();
      })
      .catch(function() {
        prizeNameEl.textContent = 'Error al cargar';
        qrCodeEl.innerHTML = '<span class="font-body-sm text-red-500">Error</span>';
      });
  }

  loadCanje();
})();
</script>

</body>
</html>