<!DOCTYPE html>
<html class="dark" lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RondaCero - Yo Nunca Nunca</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;1,400;1,500&family=Lexend:wght@600&family=Spline+Sans:wght@700;800&display=swap" rel="stylesheet"/>
  <script>
  tailwind.config={darkMode:"class",theme:{extend:{colors:{"surface-bright":"#303b41","surface-dim":"#0a151a","secondary-fixed-dim":"#5bd5fc","background":"#0a151a","inverse-surface":"#d8e4ec","on-surface":"#d8e4ec","inverse-primary":"#745c00","surface":"#0a151a","surface-container-low":"#121d23","on-primary-container":"#725a00","on-tertiary-container":"#b8005e","secondary-container":"#00a3c8","primary-container":"#ffd23f","on-error":"#690005","surface-container-highest":"#2b363d","primary-fixed":"#ffe089","surface-variant":"#2b363d","on-secondary-container":"#003341","tertiary-fixed-dim":"#ffb1c6","on-error-container":"#ffdad6","on-surface-variant":"#d1c5ad","error-container":"#93000a","secondary-fixed":"#b7eaff","outline-variant":"#4d4634","error":"#ffb4ab","surface-container-lowest":"#051015","inverse-on-surface":"#273238","on-tertiary-fixed":"#3f001c","tertiary-container":"#ffc9d6","on-secondary-fixed":"#001f28","on-tertiary":"#650031","on-primary-fixed":"#241a00","primary-fixed-dim":"#edc22e","tertiary":"#fff0f2","surface-tint":"#edc22e","surface-container-high":"#202b32","on-secondary-fixed-variant":"#004e61","secondary":"#5bd5fc","on-primary-fixed-variant":"#574500","on-secondary":"#003543","on-primary":"#3d2f00","primary":"#fff2d7","outline":"#9a907a","on-background":"#d8e4ec","surface-container":"#162127","tertiary-fixed":"#ffd9e1","on-tertiary-fixed-variant":"#8e0048"},fontFamily:{"body-sm":["Be Vietnam Pro"],"body-lg":["Be Vietnam Pro"],"headline-xl":["Spline Sans"],"label-bold":["Lexend"],"bilingual-sub":["Be Vietnam Pro"],"headline-md":["Spline Sans"]},fontSize:{"body-sm":["14px",{"lineHeight":"1.5","fontWeight":"400"}],"body-lg":["18px",{"lineHeight":"1.6","fontWeight":"400"}],"headline-xl":["48px",{"lineHeight":"1.1","letterSpacing":"-0.02em","fontWeight":"800"}],"label-bold":["14px",{"lineHeight":"1.0","fontWeight":"600"}],"bilingual-sub":["12px",{"lineHeight":"1.2","fontWeight":"500"}],"headline-md":["32px",{"lineHeight":"1.2","fontWeight":"700"}]},borderRadius:{"DEFAULT":"0.25rem","lg":"0.5rem","xl":"0.75rem","full":"9999px"},spacing:{"margin":"24px","chunky-gap":"12px","gutter":"16px","container-max":"1200px","unit":"8px"}}}}
  </script>
  <style>
    .rough-border{border:4px solid #000;border-radius:4px 8px 3px 6px}
    .rough-shadow{box-shadow:4px 4px 0px 0px rgba(0,0,0,1)}
    .rough-shadow-lg{box-shadow:8px 8px 0px 0px rgba(0,0,0,1)}
    .rough-button:active{box-shadow:none;transform:translate(4px,4px)}
    .paper-stack{position:relative}
    .paper-stack::before{content:'';position:absolute;top:4px;left:-4px;right:4px;bottom:-4px;border:4px solid #000;background:#2b363d;z-index:-1;transform:rotate(-1deg)}
    .error-msg{background:#93000a;color:#ffdad6;border:2px solid black}
    .game-card{transition:transform 0.3s}
    .game-card:hover{transform:rotate(0deg) scale(1.05)!important}
    ::selection{background:#ffd23f;color:black}
    .bar-fill{transition:width 0.5s ease;background:linear-gradient(90deg,#ffd23f,#ef476f)}
  </style>
</head>
<body class="bg-background text-on-background min-h-screen font-body-lg">

<%- include('partials/header') %>

<main class="flex-1 px-gutter py-margin max-w-container-max mx-auto w-full flex flex-col items-center justify-center">

  <div class="paper-stack bg-surface-container-high rough-border rough-shadow-lg p-10 w-full max-w-2xl text-center mb-margin" style="transform: rotate(0.3deg);">
    <span class="material-symbols-outlined text-6xl text-tertiary-fixed-dim mb-unit block">psychology</span>
    <p id="afirmacion-text" class="font-headline-md text-headline-md text-on-surface italic">
      Esperando afirmación...
    </p>
  </div>

  <div id="buttons-section" class="flex flex-col sm:flex-row gap-margin w-full max-w-2xl mb-margin">
    <button id="btn-si"
            class="rough-border rough-shadow rough-button bg-error-container text-on-error-container font-label-bold text-xl px-8 py-6 uppercase tracking-wide flex-1">
      <span class="text-3xl mr-2">🔥</span>
      YO SÍ LO HICE
    </button>
    <button id="btn-nunca"
            class="rough-border rough-shadow rough-button bg-surface-container-high text-on-surface font-label-bold text-xl px-8 py-6 uppercase tracking-wide flex-1">
      <span class="text-3xl mr-2">😇</span>
      YO NUNCA
    </button>
  </div>

  <div class="w-full max-w-2xl">
    <div class="flex items-center justify-between mb-unit">
      <span class="font-label-bold text-on-surface-variant">
        <span class="material-symbols-outlined align-middle mr-1">group</span>
        <span id="response-count">0/0</span> respondieron
      </span>
      <span id="auto-advance-text" class="font-body-sm text-on-surface-variant">Siguiente ronda en...</span>
    </div>
    <div class="w-full h-4 bg-surface-container-lowest rough-border overflow-hidden">
      <div id="auto-advance-bar" class="bar-fill h-full" style="width: 100%;"></div>
    </div>
  </div>

  <div id="results-panel" class="w-full max-w-2xl mt-margin hidden">
    <div class="grid grid-cols-2 gap-chunky-gap">
      <div class="bg-error-container rough-border rough-shadow p-4 text-center">
        <p class="font-headline-md text-3xl text-on-error-container" id="count-si">0</p>
        <p class="font-label-bold text-on-error-container">LO HICIERON 🔥</p>
      </div>
      <div class="bg-surface-container-high rough-border rough-shadow p-4 text-center">
        <p class="font-headline-md text-3xl text-on-surface" id="count-nunca">0</p>
        <p class="font-label-bold text-on-surface">YO NUNCA 😇</p>
      </div>
    </div>
  </div>

</main>

<%- include('partials/footer') %>

<script src="/socket.io/socket.io.js"></script>
<script>
(function() {
  const socket = io();
  const afirmacionText = document.getElementById('afirmacion-text');
  const btnSi = document.getElementById('btn-si');
  const btnNunca = document.getElementById('btn-nunca');
  const buttonsSection = document.getElementById('buttons-section');
  const responseCount = document.getElementById('response-count');
  const autoAdvanceBar = document.getElementById('auto-advance-bar');
  const autoAdvanceText = document.getElementById('auto-advance-text');
  const resultsPanel = document.getElementById('results-panel');
  const countSi = document.getElementById('count-si');
  const countNunca = document.getElementById('count-nunca');

  let answered = false;
  let advanceInterval = null;

  btnSi.addEventListener('click', function() {
    if (answered) return;
    answered = true;
    btnSi.classList.add('ring-4', 'ring-primary-container');
    btnNunca.classList.add('opacity-40');
    socket.emit('yonunca_answer', { answer: true });
  });

  btnNunca.addEventListener('click', function() {
    if (answered) return;
    answered = true;
    btnNunca.classList.add('ring-4', 'ring-primary-container');
    btnSi.classList.add('opacity-40');
    socket.emit('yonunca_answer', { answer: false });
  });

  socket.on('yonunca_question', function(data) {
    answered = false;
    afirmacionText.textContent = data.afirmacion;
    btnSi.disabled = false;
    btnNunca.disabled = false;
    btnSi.classList.remove('ring-4', 'ring-primary-container', 'opacity-40');
    btnNunca.classList.remove('ring-4', 'ring-primary-container', 'opacity-40');
    buttonsSection.classList.remove('hidden');
    resultsPanel.classList.add('hidden');
    responseCount.textContent = '0/' + data.totalPlayers;
    autoAdvanceBar.style.width = '100%';

    let timeLeft = data.timeLimit || 15;
    const totalTime = timeLeft;
    clearInterval(advanceInterval);
    advanceInterval = setInterval(function() {
      timeLeft -= 0.1;
      const pct = Math.max(0, (timeLeft / totalTime) * 100);
      autoAdvanceBar.style.width = pct + '%';
      if (timeLeft <= 0) {
        clearInterval(advanceInterval);
        autoAdvanceBar.style.width = '0%';
      }
    }, 100);
  });

  socket.on('yonunca_progress', function(data) {
    responseCount.textContent = data.responded + '/' + data.total;
  });

  socket.on('yonunca_results', function(data) {
    clearInterval(advanceInterval);
    buttonsSection.classList.add('hidden');
    resultsPanel.classList.remove('hidden');
    countSi.textContent = data.si;
    countNunca.textContent = data.nunca;
    responseCount.textContent = data.total + '/' + data.total;
    autoAdvanceBar.style.width = '0%';
    autoAdvanceText.textContent = 'Resultados finales';
  });

  socket.on('next_round', function() {
    resultsPanel.classList.add('hidden');
    afirmacionText.textContent = 'Esperando siguiente ronda...';
    autoAdvanceText.textContent = 'Siguiente ronda en...';
  });
})();
</script>

</body>
</html>